#!/bin/bash

#SBATCH --job-name=PLMASfArgs_OneStop_RC-array
#SBATCH --output=logs/PLMASfArgs_OneStop_RC-%A_%a.out
#SBATCH --error=logs/PLMASfArgs_OneStop_RC-%A_%a.err
#SBATCH --partition=work
#SBATCH --ntasks=1
#SBATCH --nodes=1

#SBATCH --qos=basic
#SBATCH --cpus-per-task=10
#SBATCH --mem=75G
#SBATCH --array=0-9
#SBATCH --mail-type=ALL
#SBATCH --mail-user=shubi@campus.technion.ac.il

sweep_ids=(r0hb42bl 5xkvgikr s3ned9lq ekuy85yf r98plzfq 9r8r6vgl dmcc93oa xth6xeqi 4exp7ry7 5you1gy3)
SWEEP_ID=${sweep_ids[$SLURM_ARRAY_TASK_ID]}


srun --overlap --ntasks=1 --nodes=1 --cpus-per-task=$SLURM_CPUS_PER_TASK -p work \
    --container-image=/rg/berzak_prj/shubi/prj/rev05_pytorchlightning+pytorch_lightning.sqsh \
    --container-mounts="/rg/berzak_prj/shubi:/home/shubi" \
    --container-workdir=/home/shubi/eyebench_private \
    bash -c "
echo 'Starting job on $(date)'
source /home/shubi/prj/nvidia_pytorch_25_03_py3_mamba_wrapper.sh
conda activate prof_env
wandb agent EyeRead/OneStop_RC_20251118/$SWEEP_ID"
    
